# ── credentials ─────────────────────────────────────────────────────────────
FASIH_USERNAME=username_sso_anda
FASIH_PASSWORD=password_sso_anda

# ── browser ─────────────────────────────────────────────────────────────────
HEADLESS=true                       # set false biar liat proses login
DEBUG=true                          # simpan screenshot tiap langkah

# ── SSO ─────────────────────────────────────────────────────────────────────
# FASIH_URL=https://fasih-sm.bps.go.id
# FASIH_SSO_BUTTON=Login SSO BPS    # teks tombol SSO di halaman awal

# ── crawl ───────────────────────────────────────────────────────────────────
SURVEY_PERIOD_ID=fd68e454-ba45-4b85-8205-f3bf777ded24
SURVEY_ROLE_ID=6d7d919a-45e5-4779-bb87-2905b49fd31a
PAGE_SIZE=10                        # data per halaman
CONCURRENCY=5                       # request paralel maksimal
DELAY_MS=1000                       # delay antar batch (ms)
MAX_RETRIES=3                       # maksimal retry untuk halaman gagal
# OUTPUT=results/progress-pencacah.json

# ── filter kab/kota (opsional) ─────────────────────────────────────────────
# Kode kab/kota BPS, 2 digit (misal '61' = Kalbar, '71' = Pontianak).
# Pisahkan dengan koma untuk multiple. Kosongkan = semua kab/kota.
KABUPATEN_CODES=

# Level ringkasan wilayah: 5 = SLS (14-digit), 6 = Sub-SLS (16-digit)
REGION_SUMMARY_LEVEL=6

# ── Google Sheets Sync ──────────────────────────────────────────────────────
SYNC_TO_GOOGLE_SHEETS=true
GOOGLE_APPLICATION_CREDENTIALS=nama-file-key-google-cloud-anda.json
# Buka Google Sheet Anda, salin ID dari URL (antara /d/ dan /edit)
SPREADSHEET_ID=id_google_sheet_anda_disini
SPREADSHEET_RANGE=6100!A1

# ── Scheduler ───────────────────────────────────────────────────────────────
# Penjadwalan: format cron (default setiap jam 8 pagi)
CRON_SCHEDULE="0 8 * * *"
